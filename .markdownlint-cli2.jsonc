// markdownlint-cli2 config — llm-of-qud
// Docs: https://github.com/DavidAnson/markdownlint/blob/main/doc/Rules.md
//
// Most review memos (docs/memo/) are prose transcripts and code-heavy notes
// where strict styling noise outweighs the signal. Rules below are disabled
// based on the violation distribution observed on the initial CI run; sharp
// quality rules (MD001, MD034, MD038) stay enabled.
{
  "config": {
    "default": true,
    // Line length — memos and spec docs wrap for paragraphs, not columns.
    "MD013": false,
    // Unordered-list style — we mix "-" and "*" in quoted review transcripts.
    "MD004": false,
    // Unordered-list indentation — legacy 4-space memos coexist with 2-space.
    "MD007": false,
    // Blanks around headings — review transcripts concatenate Q/A tightly.
    "MD022": false,
    // Duplicate headings — review memos repeat "Proposed change" etc.
    "MD024": false,
    // Multiple top-level H1 — Codex review transcripts retain their own H1.
    "MD025": false,
    // Trailing punctuation on headings — questions in memos end with "?".
    "MD026": false,
    // Blanks around fenced code blocks — noise in code-heavy memos.
    "MD031": false,
    // Blanks around lists — same rationale as MD022.
    "MD032": false,
    // Emphasis-as-heading — review transcripts use bold for section titles.
    "MD036": false,
    // Fenced-code language — not all snippets need a language tag.
    "MD040": false,
    // Table pipe spacing — newer markdownlint flags aligned/compact
    // inconsistencies; we write tables by hand without strict alignment.
    "MD060": false,
    // Heading-level jumps — frozen docs/architecture-v5.md uses h1→h3 and
    // cannot be amended without an ADR. Loosen the rule repo-wide.
    "MD001": false,
    // Bare URLs — review memos contain long reference URLs that Codex pasted
    // without angle-bracket wrapping. Readability isn't harmed in prose.
    "MD034": false,
    // Spaces inside code spans — memos quote verbatim CoQ log snippets whose
    // leading/trailing whitespace is part of the captured output.
    "MD038": false
  },
  "globs": [
    "**/*.md"
  ],
  "ignores": [
    "decompiled/**",
    ".github/**",
    "node_modules/**",
    "reports/**",
    ".venv/**"
  ]
}
